{
  "info": {
    "name": "Travela API",
    "description": "Postman Collection cho BookingTourDuLich API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "userToken", "value": "" },
    { "key": "adminToken", "value": "" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@gmail.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Tours",
      "item": [
        {
          "name": "Get All Tours",
          "request": { "method": "GET", "url": "{{baseUrl}}/tours?page=1&limit=9" }
        },
        {
          "name": "Get Popular Tours",
          "request": { "method": "GET", "url": "{{baseUrl}}/tours/popular?limit=4" }
        },
        {
          "name": "Get Domain Counts",
          "request": { "method": "GET", "url": "{{baseUrl}}/tours/domains" }
        },
        {
          "name": "Filter Tours",
          "request": { "method": "GET", "url": "{{baseUrl}}/tours?minPrice=100000&maxPrice=500000&domain=n&sorting=low-to-high" }
        },
        {
          "name": "Get Tour Detail",
          "request": { "method": "GET", "url": "{{baseUrl}}/tours/4" }
        }
      ]
    },
    {
      "name": "Booking",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/bookings",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tourId\": 4,\n  \"numAdults\": 2,\n  \"numChildren\": 1,\n  \"totalPrice\": 350000,\n  \"paymentMethod\": \"cash\"\n}"
            }
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/bookings/1/cancel",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tourId\": 4,\n  \"numAdults\": 2,\n  \"numChildren\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/reviews",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tourId\": 4,\n  \"message\": \"Tour rất tuyệt vời!\",\n  \"rating\": 5\n}"
            }
          }
        },
        {
          "name": "Get Reviews by Tour",
          "request": { "method": "GET", "url": "{{baseUrl}}/reviews/tour/4" }
        }
      ]
    },
    {
      "name": "Contact",
      "item": [
        {
          "name": "Submit Contact",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/contacts",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyễn Văn A\",\n  \"phone\": \"0912345678\",\n  \"email\": \"nguyenvana@gmail.com\",\n  \"message\": \"Tôi muốn hỏi về tour Đà Nẵng\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search by Destination",
          "request": { "method": "GET", "url": "{{baseUrl}}/search?destination=dn&start_date=07/03/2026&end_date=11/03/2026" }
        },
        {
          "name": "Search by Keyword",
          "request": { "method": "GET", "url": "{{baseUrl}}/search/keyword?keyword=đà nẵng" }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Get All Tours (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/tours",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Create Tour",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/tours",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tour Hạ Long 4N3Đ\",\n  \"destination\": \"Hạ Long\",\n  \"domain\": \"b\",\n  \"number\": 20,\n  \"price_adult\": 250000,\n  \"price_child\": 150000,\n  \"start_date\": \"15/04/2026\",\n  \"end_date\": \"19/04/2026\",\n  \"description\": \"Tour khám phá vịnh Hạ Long\"\n}"
            }
          }
        },
        {
          "name": "Get All Bookings (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/bookings",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Confirm Booking",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/admin/bookings/1/confirm",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Block User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/admin/users/1/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"b\"\n}"
            }
          }
        },
        {
          "name": "Get All Contacts (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/contacts",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    }
  ]
}
